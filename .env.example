# m0lz.01 — Blog Agent Environment Variables
# Copy to .env and fill in your values

# Required for cross-posting to Dev.to
DEVTO_API_KEY=

# Required for companion repo creation and PR management
GITHUB_TOKEN=

# Optional — Medium integration token (deprecated API, fallback to paste-ready)
MEDIUM_TOKEN=

# Optional — Substack API access (fallback to paste-ready)
SUBSTACK_API_KEY=

# Optional — Claude API key (fallback if not using Claude Code subscription)
ANTHROPIC_API_KEY=

# Optional — Vercel deploy status polling
VERCEL_TOKEN=
